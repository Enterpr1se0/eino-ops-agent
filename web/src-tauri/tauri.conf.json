{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpsPilot",
  "version": "0.1.2",
  "identifier": "io.opspilot.desktop",
  "build": {
    "beforeDevCommand": "npm run build && npm run desktop:prepare && npm run dev",
    "devUrl": "http://localhost:5173/desktop.html",
    "beforeBuildCommand": "npm run build && npm run desktop:prepare",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpsPilot",
        "url": "desktop.html",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/ops-agent"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-assisted SSH operations",
    "longDescription": "OpsPilot desktop application for audited SSH operations.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
